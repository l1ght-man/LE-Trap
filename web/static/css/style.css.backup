
/* ============================================================================
   HoneyPot Dashboard - Professional Dark Theme
   ============================================================================ */

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap');

/* CSS Variables */
:root {
    --bg-primary: #0f0f23;
    --bg-secondary: #1a1a2e;
    --bg-panel: rgba(26, 26, 46, 0.8);
    --bg-panel-hover: rgba(31, 31, 51, 0.9);
    --accent-green: #00ff88;
    --accent-green-glow: rgba(0, 255, 136, 0.4);
    --accent-red: #ff0055;
    --accent-blue: #00d4ff;
    --accent-purple: #a855f7;
    --accent-yellow: #fbbf24;
    --text-primary: #f5f5f7;
    --text-secondary: #a8a8b3;
    --border-color: rgba(0, 255, 136, 0.15);
    --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.2);
    --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.3);
    --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.4);
    --glow-green: 0 0 20px var(--accent-green-glow);
    --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* Reset */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* Base Styles */
body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: linear-gradient(135deg, #0a0a1a 0%, #1a1a2e 50%, #0f0f23 100%);
    background-attachment: fixed;
    color: var(--text-primary);
    min-height: 100vh;
    line-height: 1.6;
    overflow-x: hidden;
}

/* Animated background */
body::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: 
        radial-gradient(circle at 20% 50%, rgba(0, 255, 136, 0.03) 0%, transparent 50%),
        radial-gradient(circle at 80% 80%, rgba(0, 212, 255, 0.03) 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
}

.container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    z-index: 1;
}

/* Header */
.header {
    background: rgba(15, 15, 35, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border-color);
    padding: 20px 0;
    box-shadow: var(--shadow-md);
    position: sticky;
    top: 0;
    z-index: 100;
    transition: var(--transition);
}

.header:hover {
    border-bottom-color: var(--accent-green);
}

.header .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.header h1 {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    text-shadow: var(--glow-green);
    letter-spacing: -0.5px;
    display: flex;
    align-items: center;
    gap: 12px;
}

.header h1::after {
    content: '';
    width: 8px;
    height: 8px;
    background: var(--accent-green);
    border-radius: 50%;
    box-shadow: var(--glow-green);
    animation: pulse-glow 2s ease-in-out infinite;
}

@keyframes pulse-glow {
    0%, 100% { 
        opacity: 1;
        transform: scale(1);
    }
    50% { 
        opacity: 0.5;
        transform: scale(1.2);
    }
}

.status {
    display: flex;
    align-items: center;
    gap: 12px;
}

.status-indicator {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 20px;
    background: rgba(0, 255, 136, 0.08);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border-color);
    border-radius: 24px;
    font-size: 0.875rem;
    font-weight: 500;
    transition: var(--transition);
    cursor: default;
}

.status-indicator:hover {
    background: rgba(0, 255, 136, 0.12);
    border-color: var(--accent-green);
    transform: translateY(-1px);
}

.status-indicator .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent-green);
    box-shadow: 0 0 10px var(--accent-green);
    animation: pulse-dot 2s ease-in-out infinite;
}

@keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
}

.status-indicator.connected {
    border-color: rgba(0, 255, 136, 0.3);
}

.status-indicator.connected .dot {
    background: var(--accent-green);
}

.status-indicator.disconnected {
    background: rgba(255, 0, 85, 0.08);
    border-color: rgba(255, 0, 85, 0.3);
}

.status-indicator.disconnected .dot {
    background: var(--accent-red);
    box-shadow: 0 0 10px var(--accent-red);
}

/* Stats Section */
.stats-section {
    padding: 32px 0;
    position: relative;
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
}

.stat-card {
    background: var(--bg-panel);
    backdrop-filter: blur(20px);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 24px;
    text-align: center;
    transition: var(--transition);
    cursor: default;
    position: relative;
    overflow: hidden;
}

.stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--accent-green), transparent);
    opacity: 0;
    transition: var(--transition);
}

.stat-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent-green);
    box-shadow: var(--shadow-lg), var(--glow-green);
    background: var(--bg-panel-hover);
}

.stat-card:hover::before {
    opacity: 1;
}

.stat-card.highlight {
    border-color: rgba(255, 0, 85, 0.3);
}

.stat-card.highlight:hover {
    border-color: var(--accent-red);
    box-shadow: var(--shadow-lg), 0 0 20px rgba(255, 0, 85, 0.3);
}

.stat-icon {
    font-size: 2.5rem;
    margin-bottom: 12px;
    filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.3));
    animation: float 3s ease-in-out infinite;
}

@keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
}

.stat-card:hover .stat-icon {
    animation: bounce 0.6s ease;
}

@keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
}

.stat-value {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--accent-green);
    text-shadow: var(--glow-green);
    margin: 12px 0;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: -1px;
    transition: var(--transition);
}

.stat-card:hover .stat-value {
    transform: scale(1.1);
}

.stat-label {
    font-size: 0.875rem;
    color: var(--text-secondary);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

/* Filter Section */
.filter-section {
    padding: 16px 0;
    background: rgba(0, 0, 0, 0.2);
    border-bottom: 1px solid var(--border-color);
}

.filter-panel {
    display: flex;
    gap: 16px;
    align-items: flex-end;
    flex-wrap: wrap;
}

.filter-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
    min-width: 180px;
}

.filter-group label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-secondary);
}

.filter-input,
.filter-select {
    padding: 10px 14px;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-primary);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    transition: var(--transition);
}

.filter-input:focus,
.filter-select:focus {
    outline: none;
    border-color: var(--accent-green);
    background: rgba(0, 255, 136, 0.05);
    box-shadow: 0 0 0 3px rgba(0, 255, 136, 0.1);
}

.filter-input::placeholder {
    color: var(--text-secondary);
    opacity: 0.5;
}

.filter-select {
    cursor: pointer;
}

.filter-select option {
    background: var(--bg-secondary);
    color: var(--text-primary);
}

.export-buttons {
    display: flex;
    gap: 8px;
}

.btn-export {
    flex: 1;
    padding: 10px 14px;
    background: rgba(0, 255, 136, 0.1);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--accent-green);
    font-weight: 600;
    font-size: 0.875rem;
    cursor: pointer;
    transition: var(--transition);
    font-family: inherit;
}

.btn-export:hover {
    background: rgba(0, 255, 136, 0.2);
    border-color: var(--accent-green);
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm), 0 0 15px rgba(0, 255, 136, 0.2);
}

.btn-export:active {
    transform: translateY(0);
}

/* Main Content */
.main-content {
    padding: 24px 0 48px;
}

.content-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 24px;
}

@media (max-width: 1024px) {
    .content-grid {
        grid-template-columns: 1fr;
    }
}

/* Panels */
.panel {
    background: var(--bg-panel);
    backdrop-filter: blur(20px);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: var(--transition);
}

.panel:hover {
    border-color: rgba(0, 255, 136, 0.3);
    box-shadow: var(--shadow-lg);
}

.panel-header {
    padding: 20px 24px;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(0, 0, 0, 0.2);
}

.panel-header h2 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 10px;
}

.panel-badge {
    padding: 6px 14px;
    background: rgba(0, 255, 136, 0.1);
    border: 1px solid var(--border-color);
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent-green);
    font-family: 'JetBrains Mono', monospace;
}

.panel-body {
    padding: 24px;
}

/* Buttons */
.btn-small {
    padding: 8px 16px;
    background: rgba(0, 255, 136, 0.1);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--accent-green);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: var(--transition);
    font-family: inherit;
}

.btn-small:hover {
    background: rgba(0, 255, 136, 0.2);
    border-color: var(--accent-green);
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm), 0 0 15px rgba(0, 255, 136, 0.2);
}

.btn-small:active {
    transform: translateY(0);
}

/* Map Styles */
.map-panel .panel-body {
    padding: 0;
    position: relative;
    min-height: 500px;
}

#attackMap {
    width: 100%;
    height: 500px;
    display: none;
    border-radius: 0 0 16px 16px;
}

.map-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 500px;
    color: var(--text-secondary);
    gap: 16px;
}

.map-placeholder p {
    font-size: 1.1rem;
    margin: 0;
}

.map-placeholder .small {
    font-size: 0.875rem;
    color: var(--text-secondary);
    opacity: 0.7;
}

/* IP List */
.ip-list {
    max-height: 500px;
    overflow-y: auto;
    padding-right: 8px;
}

.ip-list::-webkit-scrollbar {
    width: 6px;
}

.ip-list::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.2);
    border-radius: 10px;
}

.ip-list::-webkit-scrollbar-thumb {
    background: var(--border-color);
    border-radius: 10px;
    transition: var(--transition);
}

.ip-list::-webkit-scrollbar-thumb:hover {
    background: var(--accent-green);
}

.ip-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 16px;
    margin-bottom: 8px;
    background: rgba(0, 0, 0, 0.2);
    border-left: 3px solid var(--accent-blue);
    border-radius: 6px;
    font-family: 'JetBrains Mono', monospace;
    transition: var(--transition);
    opacity: 0;
    animation: slideIn 0.4s ease forwards;
    animation-delay: calc(var(--delay, 0) * 0.05s);
}

.ip-item:hover {
    background: rgba(0, 212, 255, 0.1);
    border-left-color: var(--accent-green);
    transform: translateX(4px);
    box-shadow: var(--shadow-sm);
}

.ip-address {
    color: var(--accent-yellow);
    font-weight: 600;
    font-size: 0.95rem;
}

.ip-count {
    color: var(--accent-green);
    font-weight: 600;
    font-size: 0.9rem;
    background: rgba(0, 255, 136, 0.1);
    padding: 4px 12px;
    border-radius: 12px;
    border: 1px solid var(--border-color);
}

/* Live Feed */
.live-feed {
    max-height: 500px;
    overflow-y: auto;
    padding-right: 8px;
}

.live-feed::-webkit-scrollbar {
    width: 6px;
}

.live-feed::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.2);
    border-radius: 10px;
}

.live-feed::-webkit-scrollbar-thumb {
    background: var(--border-color);
    border-radius: 10px;
    transition: var(--transition);
}

.live-feed::-webkit-scrollbar-thumb:hover {
    background: var(--accent-green);
}

.feed-item {
    padding: 14px;
    margin-bottom: 10px;
    background: rgba(0, 0, 0, 0.2);
    border-left: 3px solid var(--accent-blue);
    border-radius: 6px;
    font-size: 0.875rem;
    transition: var(--transition);
    opacity: 0;
    animation: slideIn 0.4s ease forwards;
    display: flex;
    align-items: flex-start;
    gap: 12px;
}

@keyframes slideIn {
    from {
        opacity: 0;
        transform: translateX(-20px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

.feed-item:hover {
    background: rgba(0, 212, 255, 0.1);
    border-left-color: var(--accent-green);
    transform: translateX(4px);
}

.feed-icon {
    font-size: 1.2rem;
    line-height: 1;
    flex-shrink: 0;
}

.feed-time {
    color: var(--accent-green);
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
    min-width: 80px;
    flex-shrink: 0;
}

.feed-ip {
    color: var(--accent-yellow);
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
}

.feed-text {
    color: var(--text-primary);
    flex: 1;
    line-height: 1.5;
}

.feed-text code {
    background: rgba(0, 255, 136, 0.1);
    padding: 2px 8px;
    border-radius: 4px;
    color: var(--accent-green);
    font-family: 'JetBrains Mono', monospace;
    border: 1px solid var(--border-color);
}

.feed-text strong {
    color: var(--accent-red);
    font-weight: 700;
}

.feed-detail {
    color: var(--text-secondary);
    font-size: 0.8rem;
    font-style: italic;
}

.feed-item.credential {
    border-left-color: var(--accent-red);
    background: rgba(255, 0, 85, 0.08);
    animation: pulse-alert 0.5s ease;
}

.feed-item.credential:hover {
    background: rgba(255, 0, 85, 0.15);
}

.feed-item.command {
    border-left-color: var(--accent-purple);
    background: rgba(168, 85, 247, 0.08);
}

.feed-item.command:hover {
    background: rgba(168, 85, 247, 0.15);
}

@keyframes pulse-alert {
    0%, 100% { 
        transform: scale(1);
        box-shadow: none;
    }
    50% { 
        transform: scale(1.02);
        box-shadow: 0 0 20px rgba(255, 0, 85, 0.3);
    }
}

/* Charts */
.chart-container {
    position: relative;
    height: 300px;
    padding: 16px;
}

canvas {
    max-height: 100%;
}

/* Utility Classes */
.text-center {
    text-align: center;
}

.mt-2 {
    margin-top: 16px;
}

/* Loading Animation */
@keyframes spin {
    to { transform: rotate(360deg); }
}

.loading {
    animation: spin 1s linear infinite;
}

/* Responsive Design */
@media (max-width: 768px) {
    .header h1 {
        font-size: 1.5rem;
    }
    
    .stats-grid {
        grid-template-columns: repeat(2, 1fr);
    }
    
    .stat-card {
        padding: 16px;
    }
    
    .stat-icon {
        font-size: 2rem;
    }
    
    .stat-value {
        font-size: 2rem;
    }
    
    .content-grid {
        grid-template-columns: 1fr !important;
    }
    
    #attackMap {
        height: 400px;
    }
}

/* Footer */
.footer {
    background: rgba(15, 15, 35, 0.95);
    backdrop-filter: blur(20px);
    border-top: 1px solid var(--border-color);
    padding: 24px 0;
    text-align: center;
    color: var(--text-secondary);
    margin-top: 48px;
}

.footer p {
    margin: 4px 0;
    font-size: 0.95rem;
}

.footer .small {
    font-size: 0.85rem;
    opacity: 0.7;
}

.footer #lastUpdate {
    color: var(--accent-green);
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
}
