FROM ubuntu:22.04
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash coreutils procps net-tools iproute2 && \
    apt-get clean && rm -rf /var/lib/apt/lists/*
# Remove dangerous binaries
RUN rm -f /bin/su /usr/bin/sudo /usr/bin/wget /usr/bin/curl /usr/bin/nc
# Fake "sensitive" files to trigger attacker interest
RUN mkdir -p /var/backups && echo "FAKE_DB_DUMP_2026.sql" > /var/backups/latest.txt
RUN echo "FAKE_API_KEYS=sk_test_xxx" > /root/.env
